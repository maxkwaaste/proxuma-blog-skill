# Proxuma Blog skill — per-user config TEMPLATE.
# Copy to ~/.config/proxuma-blog/config.env and fill in YOUR OWN access, then chmod 600 it.
#   mkdir -p ~/.config/proxuma-blog
#   cp .env.example ~/.config/proxuma-blog/config.env
#   chmod 600 ~/.config/proxuma-blog/config.env
#
# This file (the template) is the ONLY env file committed. The real config.env is gitignored.
# Do not paste real credentials into this template.

# --- WordPress / SiteGround SSH (required) ---
WP_SSH_HOST="es33.siteground.eu"
WP_SSH_PORT="18765"
WP_SSH_USER="uXXXX-xxxxxxxxxxxx"
WP_SSH_KEY="$HOME/.ssh/id_ed25519"
WP_ROOT="~/www/proxuma.io/public_html"

# --- Reference template post (the live polished post new drafts mirror) ---
REF_TEMPLATE_ID="7055"

# --- OpenRouter (OPTIONAL: only for the decorative Nano-Banana wrapper, never for charts) ---
# Leave blank unless you build the decoration step. Charts are deterministic and need no key.
OPENROUTER_API_KEY=""
