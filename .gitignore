# Secrets and per-user config — NEVER commit these
.env
*.env
config.env
!.env.example
secrets/
*.key
*.pem
id_*
*_rsa
*_ed25519

# Per-run scratch / build output (articles, charts, parsed JSON)
*-parsed.json
*-images/
/tmp/
scratch/
out/

